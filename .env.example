# Copy this file to .env and fill values before running in development
# Do NOT commit your real .env with secrets to the repository.

# Flask / App
FLASK_ENV=production
SECRET_KEY=replace-this-with-a-secure-random-value

# Database (example for Postgres)
#DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mail
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=changeme

# Optional: Discord invite URL for footer & landing. Leave unset to use the default invite.
# Set to empty to hide Community links: DISCORD_COMMUNITY_URL=
#DISCORD_COMMUNITY_URL=https://discord.gg/avZdspg2H

# AI Buddy — optional web coach (OpenAI). Tavily improves general-market answers only.
#FEATURE_AI_WEB=true
#OPENAI_API_KEY=
#TAVILY_API_KEY=

# Market data (navbar quotes + Strategy Lab daily backtests)
# Optional: Twelve Data free/paid key. Without it, Lab uses Yahoo Finance daily OHLC (free).
#TWELVEDATA_API_KEY=

# Other service credentials (Stripe, Flutterwave, Paytiko, AWS, etc.)
#STRIPE_SECRET_KEY=
#STRIPE_PRICE_PRO=
#STRIPE_PRICE_PRO_PLUS=
#STRIPE_WEBHOOK_SECRET=
#FLW_SECRET_KEY=
#FLW_PUBLIC_KEY=
#FLW_CURRENCY=USD

# Trials / promo (Pro Plus) — current + new users
# New signups: days of Pro Plus trial at registration
#TV_TRIAL_DAYS_PRO_PLUS=60
# Keep all users on effective Pro Plus while trial_ends_at / created_at+days / TV_PROMO_ACCESS_UNTIL is future
#TV_ALL_USERS_PROPLUS_TRIAL=1
#TV_ALL_USERS_PROPLUS_TRIAL_DAYS=60
# Hard end date so everyone (including expired trials) stays Pro Plus until then
#TV_PROMO_ACCESS_UNTIL=2026-09-15
# On Render boot: one-time flask grant-promo-trial (marker on persistent disk)
#TV_GRANT_PROMO_ON_START=1
# Manual grant:
#   flask grant-promo-trial --days 60

# Persistent user media (avatars, before/after trade screenshots)
# On Render: attach a disk at /var/data and set:
#TRADEVERSE_DATA_DIR=/var/data
# Local default: app/static/uploads/...

#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
